{
  "name": "ai-teaching-video-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "dev:server": "npm --prefix server run dev",
    "dev:worker": "npm --prefix server run worker",
    "dev:all": "node node_modules/concurrently/dist/bin/concurrently.js \"npm run dev:server\" \"npm run dev:worker\" \"npm run dev\"",
    "build": "node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "test": "npm --prefix server test",
    "start:api": "bash scripts/start-api.sh",
    "start:worker": "bash scripts/start-worker.sh",
    "stop:services": "bash scripts/stop-services.sh",
    "status:services": "bash scripts/status-services.sh",
    "start:backend": "bash scripts/start-api.sh && bash scripts/start-worker.sh",
    "restart:services": "bash scripts/restart-services.sh",
    "sync:server-run": "bash scripts/sync-server-run.sh",
    "start:mysql-stack": "bash scripts/start-mysql-stack.sh",
    "watchdog:services": "bash scripts/watchdog-services.sh",
    "compose:up": "bash scripts/compose-up.sh",
    "compose:down": "bash scripts/compose-down.sh",
    "compose:mysql": "bash scripts/compose-mysql-only.sh",
    "smoke:mysql": "bash scripts/smoke-mysql.sh",
    "test:p4": "npm --prefix server run test:p4",
    "test:model-settings": "npm --prefix server run test:model-settings"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
