# AI Teaching Video Platform - environment template
# Copy to .env for local API/Worker, or use .env.compose for docker compose.
# Never commit real API keys.

# =========================
# API / Runtime
# =========================
PORT=3002
USE_MYSQL=false
MEDIA_SIGNING_SECRET=replace-with-a-long-random-secret

# =========================
# MySQL
# =========================
# Local host access (USE_MYSQL=true outside containers)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=atv
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=ai_teaching_video

# Compose MySQL service
MYSQL_IMAGE=mysql:8.0
MYSQL_ROOT_PASSWORD=change-me
MYSQL_APP_USER=atv
MYSQL_APP_PASSWORD=change-me
MYSQL_HOST_PORT=3307

# =========================
# Bootstrap accounts
# =========================
ADMIN_EMAIL=teacher@demo.local
ADMIN_PASSWORD=change-me-before-production
ADMIN_NICKNAME=系统管理员
SEED_DEMO_ACCOUNTS=true
DEMO_TEACHER_EMAIL=physics.teacher@demo.local
DEMO_TEACHER_PASSWORD=demo123
DEMO_STUDENT_EMAIL=student@demo.local
DEMO_STUDENT_PASSWORD=demo123

# =========================
# Skill / worker
# =========================
TEACHING_MEDIA_ROOT=/path/to/ai-teaching-media
ARTIFACTS_ROOT=./server/data/jobs
WORKER_POLL_MS=3000
WORKER_CONCURRENCY=1

# =========================
# System model defaults
# (admin 后台默认值会优先用 system_config，缺失时回退到这些 env)
# =========================
DEFAULT_TTS_PROVIDER=edge
DEFAULT_EDGE_VOICE=zh-CN-XiaoxiaoNeural
DEFAULT_SEED_VOICE=zh_female_vv_uranus_bigtts
DEFAULT_IMAGE_PROVIDER=volcengine
DEFAULT_VIDEO_PROVIDER=hyperframes
DEFAULT_DIAGRAM_STYLE=cozy-handdrawn
MODELS_TTS_ALLOWLIST=edge,minimax,seed,say
MODELS_IMAGE_ALLOWLIST=agnes,mulerun,apimart,atlascloud,volcengine
MODELS_VIDEO_ALLOWLIST=hyperframes

# =========================
# Image providers
# =========================
AGNES_API_KEY=
MULERUN_API_KEY=
APIMART_API_KEY=
ATLASCLOUD_API_KEY=
VOLCENGINE_API_KEY=
# ARK_API_KEY=   # optional alias for VOLCENGINE_API_KEY
VOLCENGINE_API_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3
VOLCENGINE_IMAGE_MODEL=doubao-seedream-5.0-lite
VOLCENGINE_HTTP_TIMEOUT=180
VOLCENGINE_HTTP_RETRIES=2
VOLCENGINE_WATERMARK=false
AGNES_HTTP_TIMEOUT=90
AGNES_HTTP_RETRIES=1
IMAGE_HTTP_TIMEOUT=90
IMAGE_HTTP_RETRIES=1
IMAGE_GEN_TIMEOUT_MS=225000
PACKAGE_IMAGE_CONCURRENCY=3

# =========================
# TTS providers
# =========================
MINIMAX_API_KEY=
SEED_TTS_API_KEY=
# 可复用 VOLCENGINE_API_KEY / ARK_API_KEY
SEED_TTS_URL=https://openspeech.bytedance.com/api/v3/plan/tts/unidirectional
SEED_TTS_RESOURCE_ID=seed-tts-2.0
SEED_TTS_VOICE=zh_female_vv_uranus_bigtts
SEED_TTS_HTTP_TIMEOUT=120
SEED_TTS_HTTP_RETRIES=2


# =========================
# Storyboard knowledge LLM (optional)
# =========================
# 用于知识驱动分镜。未配置时回退本地知识包/启发式拆解，不阻断出片。
STORYBOARD_LLM_ENABLED=true
STORYBOARD_PREFER_KNOWLEDGE_PACK=true
STORYBOARD_LLM_TIMEOUT_MS=25000
# OpenAI-compatible chat completions endpoint
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# aliases also supported: OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL

# =========================
# HyperFrames / video
# =========================
HYPERFRAMES_QUALITY=draft
HYPERFRAMES_FPS=20
HYPERFRAMES_WORKERS=6
HYPERFRAMES_FAST_CAPTURE=true
HYPERFRAMES_LOW_MEMORY_MODE=false
HYPERFRAMES_BROWSER_PATH=
# HYPERFRAMES_EXTRA_ARGS=

# =========================
# Docker Compose only
# =========================
API_HOST_PORT=3002
ATV_APP_IMAGE=atv-app:local
NODE_IMAGE=node:22-bookworm
COMPOSE_PROFILES=web
HOST_PLAYWRIGHT_CACHE=${HOME}/.cache/ms-playwright

# Optional local runtime helpers
# USE_LOCAL_RUNTIME=1
# RUNTIME_ROOT=/tmp/atv-run
# MEMORY_DB_FILE=/tmp/atv-run/data/memory-db.json
# PYTHONPATH=/home/you/.local/lib/python3.10/site-packages
# PYTHONUNBUFFERED=1
